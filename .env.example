# Copy to .env.local and fill with your values. NEVER commit real secrets to git.
# Public URL of your site (required for unsubscribe links and canonical URLs)
NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# Database (Neon, Supabase, or any Postgres). Use pooled connection string from your provider.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me-min-12-chars"
JWT_SECRET="your-32-character-secret-key-here"

# Amazon SES (optional - for email and lead notifications)
AWS_REGION="eu-west-1"
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
SES_FROM_EMAIL="noreply@yourdomain.com"

# Optional: Vercel Blob for lead form file uploads (photos/videos). Get from Vercel Dashboard → Storage → Blob.
# Without this, uploads use local disk (dev only).
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Optional: When set, /build is protected; clients must enter this token at /client to access the build form.
# BUILD_CLIENT_TOKEN="your-secret-code-for-clients"